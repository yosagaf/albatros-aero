---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/site/Header.astro";
import Footer from "../../components/site/Footer.astro";
import "../../styles/global.css";
---

<BaseLayout title="Message envoyé — Albatros" description="Merci pour votre message.">
	<Header variant="light" />
	<main class="bg-albatros-charcoal text-white">
		<section class="mx-auto max-w-lg px-2 py-24 text-center sm:px-4 lg:px-5">
			<h1 class="font-display text-2xl font-bold text-white md:text-3xl">Merci</h1>
			<p class="mt-4 text-base leading-relaxed text-white/85">
				Votre message a bien été envoyé. Nous vous répondrons dès que possible à
				<a href="mailto:contact@albatros.team" class="font-semibold text-albatros-yellow underline-offset-2 hover:underline">
					contact@albatros.team
				</a>.
			</p>
			<a
				href="/"
				class="mt-10 inline-flex rounded-lg bg-albatros-yellow px-8 py-3.5 font-display text-sm font-bold text-white uppercase tracking-wide transition hover:bg-albatros-yellow-hover"
			>
				Retour à l’accueil
			</a>
		</section>
	</main>
	<Footer />
</BaseLayout>
