		"Mise à jour de la situation tactique plus fréquente",
		"Meilleure gestion des situations avec plusieurs feux en cours",
	]}
	features={[
		"Surveillance de très grandes surfaces de forêt",
		"Détection des feux par IA",
		"Monitoring haute résolution des feux",
		"Transmission des situations en temps réel",
		"Opération hors conflit avec les moyens aériens",
	]}
	ctaPhrase="Prêt à voir Patrol en action ?"
	ctaPrimaryLabel="Demander un rendez-vous"
	images={[
		{
			src: "/media/images/products/patrol/aircraft.png",
			alt: "Avion léger en vol — service Patrol",
		},
		{ src: "/media/images/products/patrol/interface.png", alt: "Interface CRIMSON — analyse et gestion des événements feux" },
		{ src: "/media/images/products/patrol/satellite.png", alt: "Vue satellite — périmètres de feux détectés" },
	]}
/>
