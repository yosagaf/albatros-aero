---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/site/Header.astro";
import Footer from "../../components/site/Footer.astro";
import ProductHubSection from "../../components/product/ProductHubSection.astro";
import "../../styles/global.css";

const products = [
	{
		id: "companion",
		productName: "Companion",
		subtitle: "Assistant IA feux de forêt pour vos drones",
		excerpt:
			"Plug-in optimisant vos opérations drones (DJI, Parrot, etc.) en missions feux de forêt.",
		image: "/media/images/products/grid/companion-card.jpg",
		imageAlt: "Pompier utilisant une télécommande drone devant un incendie de nuit",
		href: "/produits/companion",
		ctaLabel: "Voir le produit",
	},
	{
		id: "coperator",
		productName: "Coperator",
		subtitle: "Agent IA feux de forêt pour avions et hélicoptères",
		excerpt:
			"Couche logicielle automatisant l'essentiel des tâches chronophages pour le pilote ou l'opérateur de bord.",
		image: "/media/images/products/grid/coperator-card.webp",
		imageAlt: "Plateforme aérienne en vol au-dessus des massifs forestiers",
		href: "/produits/coperator",
		ctaLabel: "Voir le produit",
	},
	{
		id: "patrol",
		productName: "Patrol",
		subtitle: "Service clés en main de détection et monitoring par avion",
		excerpt:
			"Surveillance des forêts, détection, monitoring des feux et transmission des alertes en temps réel.",
		image: "/media/images/products/grid/patrol-card.jpg",
		imageAlt: "Avion léger bi-moteur en vol au-dessus d'un paysage rural",
		href: "/produits/patrol",
		ctaLabel: "Voir le produit",
	},
	{
		id: "drone",
		productName: "Drone",
		subtitle: "Service clés en main de détection et monitoring par drone",
		excerpt:
			"Drone autonome, surveillance, détection et alertes en temps réel.",
		image: "/media/images/products/grid/drone-card.webp",
		imageAlt: "Surveillance par drone — vol au-dessus du couvert forestier",
		badge: "Bientôt 2027",
	},
];
---

<BaseLayout
	title="Produits — Albatros"
	description="Solutions IA pour drones, avions et services clés en main — lutte contre les feux de forêt."
>
	<Header variant="overlay" />
	<main>
		<!-- Hero -->
		<section
			class="relative flex min-h-[75vh] items-end bg-cover bg-center pb-16 md:min-h-[85vh] md:items-center md:pb-24"
			style="background-image: url('/media/images/products/hero-banner.webp');"
			aria-labelledby="produits-hero-heading"
		>
			<div class="absolute inset-0 bg-black/40 md:bg-black/35"></div>
			<div class="relative z-10 mx-auto w-full max-w-site px-2 pt-28 sm:px-4 lg:px-5">
				<div class="border-l-4 border-albatros-yellow pl-4">
					<p class="mb-3 inline-block rounded bg-white/15 px-3 py-1 font-display text-xs font-semibold text-white">
						Produits
					</p>
					<h1
						id="produits-hero-heading"
						class="max-w-4xl font-display text-3xl font-extrabold tracking-tight text-white uppercase md:text-4xl lg:text-5xl"
					>
						Pour les professionnels
					</h1>
				</div>
				<a href="#companion"
					class="mt-8 inline-flex items-center justify-center rounded-lg bg-albatros-yellow px-8 py-3.5 font-display text-sm font-bold text-white uppercase tracking-wide transition hover:bg-albatros-yellow-hover"
				>
					Découvrir
				</a>
			</div>
		</section>

		<!-- Bandeau sticky de navigation produits -->
		<nav
			class="sticky top-0 z-40 border-b border-zinc-200 bg-white/95 shadow-sm backdrop-blur-sm"
			aria-label="Navigation entre les produits"
			data-products-nav
		>
			<div class="mx-auto max-w-site px-2 sm:px-4 lg:px-5">
				<ul class="flex items-center gap-2 overflow-x-auto py-3 md:justify-center md:gap-4">
					{
						products.map((p) => (
							<li class="flex-shrink-0">
								<a
									href={`#${p.id}`}
									data-product-nav-link
									data-target={p.id}
									class="inline-flex items-center rounded-full px-4 py-2 font-display text-sm font-semibold text-zinc-700 transition hover:text-albatros-yellow md:text-base"
								>
									{p.productName}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</nav>

		<!-- Sections produits -->
		{
			products.map((product, index) => (
				<ProductHubSection
					id={product.id}
					productName={product.productName}
					subtitle={product.subtitle}
					excerpt={product.excerpt}
					image={product.image}
					imageAlt={product.imageAlt}
					href={product.href}
					ctaLabel={product.ctaLabel}
					badge={product.badge}
					bgVariant={index % 2 === 0 ? "white" : "zinc"}
				/>
			))
		}

		<!-- CTA final -->
		<section class="bg-albatros-charcoal py-14 md:py-20">
			<div class="mx-auto max-w-4xl px-2 text-center sm:px-4 lg:px-5">
				<p class="font-display text-lg font-semibold text-white md:text-xl">
					Besoin d'une démo ou de plus d'informations ?
				</p>
				<a href="/contact"
					class="mt-8 inline-flex items-center justify-center rounded-lg bg-albatros-yellow px-8 py-3.5 font-display text-sm font-bold text-white uppercase tracking-wide transition hover:bg-albatros-yellow-hover"
				>
					Nous contacter
				</a>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>

<script>
	function initProductsScrollSpy() {
		const nav = document.querySelector<HTMLElement>("[data-products-nav]");
		if (!nav) return;

		const links = Array.from(
			nav.querySelectorAll<HTMLAnchorElement>("[data-product-nav-link]")
		);
		if (links.length === 0) return;

		const activeClasses = ["bg-albatros-yellow/15", "text-albatros-yellow"];
		const inactiveClasses = ["text-zinc-700"];

		const setActive = (targetId: string | null) => {
			links.forEach((link) => {
				const isActive = link.dataset.target === targetId;
				activeClasses.forEach((cls) => link.classList.toggle(cls, isActive));
				inactiveClasses.forEach((cls) => link.classList.toggle(cls, !isActive));
			});
		};

		const sections = links
			.map((link) => {
				const id = link.dataset.target;
				if (!id) return null;
				return document.getElementById(id);
			})
			.filter((el): el is HTMLElement => el !== null);

		const observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((entry) => entry.isIntersecting)
					.sort((a, b) => b.intersectionRatio - a.intersectionRatio);

				if (visible.length > 0) {
					setActive(visible[0].target.id);
				}
			},
			{
				rootMargin: "-40% 0px -50% 0px",
				threshold: [0, 0.25, 0.5, 0.75, 1],
			}
		);

		sections.forEach((section) => observer.observe(section));
	}

	initProductsScrollSpy();
	document.addEventListener("astro:after-swap", initProductsScrollSpy);
</script>
