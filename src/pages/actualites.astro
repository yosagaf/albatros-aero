---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";
import ContactForm from "../components/contact/ContactForm.astro";
import "../styles/global.css";

const articles = [
	{
		title: "Présent au Congrès des Sapeurs-pompiers 2025",
		date: "8 octobre 2025",
		excerpt:
			"Retour sur nos échanges avec les opérateurs aériens et les SDIS autour de la détection précoce et du partage d'information.",
		details:
			"Le Congrès national des Sapeurs-pompiers 2025 a été l'occasion pour Albatros de présenter ses solutions de détection et de monitoring aérien aux décideurs du monde de la sécurité civile. Nos équipes ont pu échanger directement avec les SDIS sur les enjeux opérationnels de la surveillance des feux de forêt et démontrer comment nos technologies permettent une réponse plus rapide et mieux coordonnée sur le terrain.",
		image: "/media/images/news/firefighters-congress.jpeg",
	},
	{
		title: "Albatros au salon du Bourget 2025",
		date: "17 juin 2025",
		excerpt:
			"Retour sur notre présence au salon du Bourget et les rencontres avec les acteurs de la surveillance aérienne et de la lutte contre les feux.",
		details:
			"Au salon international de l'aéronautique et de l'espace du Bourget, Albatros a présenté ses capacités de surveillance et de détection des feux de forêt par voie aérienne. Ce rendez-vous majeur a permis de rencontrer des partenaires industriels, des opérateurs aériens et des représentants institutionnels intéressés par nos solutions de monitoring en temps réel.",
		image: "/media/images/news/paris-air-show.jpeg",
	},
	{
		title: "Albatros expose au rendez-vous mondiale des professionnels",
		date: "26 mars 2025",
		excerpt:
			"Présentation de nos solutions de détection et monitoring aérien lors des rendez-vous mondiaux de la sécurité civile.",
		details:
			"Lors des rendez-vous mondiaux de la sécurité civile, Albatros a exposé ses solutions innovantes de détection précoce et de monitoring des feux de forêt. Cet événement international a rassemblé les acteurs majeurs de la protection civile, offrant une vitrine idéale pour démontrer l'efficacité de nos systèmes de surveillance aérienne auprès d'un public de professionnels.",
		image: "/media/images/news/world-conference.jpeg",
	},
	{
		title: "En partenariat avec les pompiers de l'Aude, une expérimentation",
		date: "12 février 2024",
		excerpt:
			"Dans l'objectif de faire face à l'augmentation du risque, le SDIS 11 trouve en Albatros une des solutions pour l'avenir.",
		details:
			"En collaboration avec le SDIS de l'Aude, Albatros a mené une expérimentation en conditions réelles pour évaluer la détection précoce des feux de forêt et l'appui aux équipes sur le terrain. Face à l'augmentation du risque incendie dans le département, ce partenariat vise à tester et valider des solutions technologiques permettant d'améliorer la réactivité et l'efficacité des interventions.",
		image: "/media/images/technology/hero-banner.webp",
	},
];
---

<BaseLayout title="Actualités — Albatros" description="Actualités, événements et publications Albatros.">
	<Header variant="light" />
	<main>
		<section class="bg-white py-14 text-zinc-900 md:py-20" aria-labelledby="actu-heading">
			<div class="mx-auto max-w-site px-2 sm:px-4 lg:px-5">
				<h1 id="actu-heading" class="text-center font-display text-2xl font-extrabold uppercase tracking-tight text-albatros-title-grey md:text-3xl lg:text-4xl">
					L'actualité d'Albatros
				</h1>
				<div class="mx-auto mt-4 h-1 w-16 rounded-full bg-albatros-yellow"></div>
				<div class="mt-14 grid gap-8 md:grid-cols-2">
					{
						articles.map((a) => (
							<article class="card-hover flex overflow-hidden rounded-xl border border-zinc-200 bg-zinc-50/80 shadow-sm">
								<div class="grid h-full w-full sm:grid-cols-5">
									<div class="relative sm:col-span-2 sm:min-h-[220px]">
										<img src={a.image} alt="" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
									</div>
									<div class="flex flex-col p-5 sm:col-span-3 sm:p-6">
										<h2 class="font-display text-base font-bold text-albatros-title-grey md:text-lg">{a.title}</h2>
										<p class="mt-2 font-display text-xs font-medium text-zinc-500">{a.date}</p>
										<p class="mt-3 text-sm leading-relaxed text-zinc-600">{a.excerpt}</p>
										<p class="mt-2 text-sm leading-relaxed text-zinc-500">{a.details}</p>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="border-t border-white/10 bg-albatros-charcoal py-16 text-white md:py-20" id="ecrivez-nous">
			<div class="mx-auto max-w-4xl px-2 sm:px-4 lg:px-5">
				<h2 class="text-center font-display text-xl font-semibold md:text-2xl">Écrivez-nous !</h2>
				<ContactForm formName="actualites" idPrefix="actualites" class="mt-10 space-y-5" />
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
