---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../site/Header.astro";
import Footer from "../site/Footer.astro";
import "../../styles/global.css";

interface Props {
	title: string;
	description: string;
	productName: string;
	subtitle: string;
	introTitle: string;
	introParagraphs: string[];
	whyTitle: string;
	bullets: string[];
	features: string[];
	ctaPhrase: string;
	ctaPrimaryLabel: string;
	ctaSecondaryLabel?: string;
	images: { src: string; alt: string }[];
	lang?: "fr" | "en";
}

const {
	title,
	description,
	productName,
	subtitle,
	introTitle,
	introParagraphs,
	whyTitle,
	bullets,
	features,
	ctaPhrase,
	ctaPrimaryLabel,
	ctaSecondaryLabel,
	images,
	lang = "fr",
} = Astro.props;

const en = lang === "en";
const contactHref = en ? "/en/contact" : "/contact";
const productBadge = en ? "Products" : "Produits";
const featuresHeading = en ? "Key features" : "Fonctionnalités principales";
const secondary =
	ctaSecondaryLabel ?? (en ? "Contact us" : "Nous contacter");
---

<BaseLayout {title} {description} lang={lang}>
	<Header variant="light" />
	<main>
		<section class="bg-albatros-charcoal pt-28 pb-16 md:pt-32 md:pb-20" aria-labelledby="product-hero-title">
			<div class="mx-auto max-w-site px-2 sm:px-4 lg:px-5">
				<div class="border-l-4 border-albatros-yellow pl-4">
					<p class="mb-3 inline-block rounded bg-white/10 px-3 py-1 font-display text-xs font-semibold text-white/90">
						{productBadge}
					</p>
					<h1
						id="product-hero-title"
						class="font-display text-3xl font-extrabold tracking-tight text-white uppercase md:text-4xl lg:text-5xl"
					>
						{productName}
					</h1>
					<p class="mt-4 max-w-3xl font-display text-base font-semibold text-albatros-yellow md:text-lg">
						{subtitle}
					</p>
				</div>
				<div class="mt-8 flex flex-wrap gap-4">
					<a href={contactHref}
						class="inline-flex items-center justify-center rounded-lg bg-albatros-yellow px-8 py-3.5 font-display text-sm font-bold text-white uppercase tracking-wide transition hover:bg-albatros-yellow-hover"
					>
						{ctaPrimaryLabel}
					</a>
					<a href={contactHref}
						class="inline-flex items-center justify-center rounded-lg border-2 border-white px-8 py-3.5 font-display text-sm font-semibold text-white uppercase tracking-wide transition hover:bg-white/10"
					>
						{secondary}
					</a>
				</div>
			</div>
		</section>

		<section class="bg-white py-14 text-zinc-900 md:py-20">
			<div class="mx-auto max-w-site px-2 sm:px-4 lg:px-5">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-16">
					<div>
						<h2 class="font-display text-xl font-bold text-albatros-yellow md:text-2xl">
							{introTitle}
						</h2>
						{
							introParagraphs.map((p) => (
								<p class="mt-4 text-sm leading-relaxed md:text-base">
									{p}
								</p>
							))
						}
						<h3 class="mt-10 font-display text-lg font-bold text-albatros-yellow md:text-xl">
							{whyTitle}
						</h3>
						<ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed md:text-base">
							{bullets.map((b) => (
								<li>{b}</li>
							))}
						</ul>
					</div>
					<div class="mx-auto flex w-3/4 flex-col gap-6 lg:w-full lg:max-w-[75%]">
						{
							images.map(({ src, alt }) => (
								<div class="overflow-hidden rounded-lg shadow-md ring-1 ring-zinc-200">
									<img src={src} alt={alt} class="h-auto w-full object-cover" loading="lazy" />
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="bg-zinc-100 py-14 md:py-20" aria-labelledby="features-heading">
			<div class="mx-auto max-w-site px-2 sm:px-4 lg:px-5">
				<h2
					id="features-heading"
					class="text-center font-display text-xl font-bold text-albatros-yellow md:text-2xl"
				>
					{featuresHeading}
				</h2>
				<div class="mx-auto mt-10 flex max-w-5xl flex-wrap justify-center gap-4">
					{
						features.map((f) => (
							<div class="flex min-h-[5rem] w-full items-center justify-center gap-3 rounded-xl border border-zinc-200 bg-white px-6 py-5 text-center font-display text-sm font-semibold text-zinc-800 shadow-sm sm:w-[calc(33.333%-1rem)] md:text-base">
								<span class="inline-block h-2 w-2 flex-shrink-0 rounded-full bg-albatros-yellow"></span>
								{f}
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="bg-albatros-charcoal py-14 md:py-20">
			<div class="mx-auto max-w-4xl px-2 text-center sm:px-4 lg:px-5">
				<p class="font-display text-lg font-semibold text-white md:text-xl">
					{ctaPhrase}
				</p>
				<a href={contactHref}
					class="mt-8 inline-flex items-center justify-center rounded-lg bg-albatros-yellow px-8 py-3.5 font-display text-sm font-bold text-white uppercase tracking-wide transition hover:bg-albatros-yellow-hover"
				>
					{ctaPrimaryLabel}
				</a>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
