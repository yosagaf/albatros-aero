---
interface Props {
	id: string;
	productName: string;
	subtitle: string;
	excerpt: string;
	image: string;
	imageAlt: string;
	href?: string;
	ctaLabel?: string;
	badge?: string;
	bgVariant?: "white" | "zinc";
	productBadge?: string;
}

const {
	id,
	productName,
	subtitle,
	excerpt,
	image,
	imageAlt,
	href,
	ctaLabel,
	badge,
	bgVariant = "white",
	productBadge,
} = Astro.props;

const sectionBg = bgVariant === "white" ? "bg-white" : "bg-zinc-100";
---

<section
	id={id}
	class:list={["scroll-mt-28 py-16 md:py-24", sectionBg]}
	aria-labelledby={`${id}-title`}
>
	<div class="mx-auto max-w-site px-2 sm:px-4 lg:px-5">
		<div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
			<div class="overflow-hidden rounded-xl shadow-md ring-1 ring-zinc-200">
				<img
					src={image}
					alt={imageAlt}
					class="h-full w-full object-cover"
					loading="lazy"
				/>
			</div>
			<div>
				<div class="border-l-4 border-albatros-yellow pl-4">
					{
						productBadge && (
							<p class="mb-3 inline-block rounded bg-zinc-900/5 px-3 py-1 font-display text-xs font-semibold text-zinc-700">
								{productBadge}
							</p>
						)
					}
					<h2
						id={`${id}-title`}
						class="font-display text-2xl font-extrabold uppercase tracking-tight text-albatros-title-grey md:text-3xl lg:text-4xl"
					>
						{productName}
					</h2>
					<p class="mt-3 font-display text-base font-semibold text-albatros-yellow md:text-lg">
						{subtitle}
					</p>
				</div>
				<p class="mt-5 text-sm leading-relaxed text-zinc-600 md:text-base">
					{excerpt}
				</p>
				<div class="mt-6 flex flex-wrap items-center gap-4">
					{
						href && ctaLabel && (
							<a
								href={href}
								class="inline-flex items-center justify-center rounded-lg bg-albatros-yellow px-6 py-3 font-display text-sm font-bold text-white uppercase tracking-wide transition hover:bg-albatros-yellow-hover"
							>
								{ctaLabel}
							</a>
						)
					}
					{
						badge && (
							<span class="inline-flex items-center rounded-full border border-albatros-yellow bg-albatros-yellow/10 px-4 py-2 font-display text-xs font-bold uppercase tracking-wide text-albatros-yellow">
								{badge}
							</span>
						)
					}
				</div>
			</div>
		</div>
	</div>
</section>
